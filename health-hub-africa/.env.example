# Public API base URL — set this in Vercel environment variables
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Sentry ──────────────────────────────────────────────────────
# DSN is public — safe to expose in browser bundles
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oXXXXX.ingest.sentry.io/XXXXXXX
# Auth token, org, and project are used only at build time for source map uploads
SENTRY_AUTH_TOKEN=
SENTRY_ORG=health-hub-africa
SENTRY_PROJECT=health-vault-frontend
