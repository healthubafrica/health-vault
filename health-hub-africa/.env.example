# Public API base URL — set this in Vercel environment variables
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Sentry ──────────────────────────────────────────────────────
# DSN is public — safe to expose in browser bundles
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oXXXXX.ingest.sentry.io/XXXXXXX
# Auth token, org, and project are used only at build time for source map uploads
SENTRY_AUTH_TOKEN=
SENTRY_ORG=health-hub-africa
SENTRY_PROJECT=health-vault-frontend

# ─── Firebase (Client SDK Config) ──────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── LiveKit (Video Consultation) ──────────────────────────────
NEXT_PUBLIC_LIVEKIT_URL=
