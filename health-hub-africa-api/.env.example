# ─── App ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/hha_db?schema=public

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_EXPIRY=900
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_REFRESH_EXPIRY=604800

# ─── AWS S3 / Cloudflare R2 ──────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=hha-documents
SIGNED_URL_EXPIRY_SECONDS=3600
# For Cloudflare R2 set endpoint:
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# ─── Paystack ────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_
PAYSTACK_PUBLIC_KEY=pk_live_

# ─── Flutterwave ─────────────────────────────────────────────────
FLUTTERWAVE_SECRET_KEY=FLWSECK_
FLUTTERWAVE_ENCRYPTION_KEY=

# ─── OpenEMR ─────────────────────────────────────────────────────
OPENEMR_BASE_URL=https://emr.yourdomain.com
OPENEMR_CLIENT_ID=
OPENEMR_CLIENT_SECRET=

# ─── Twilio (SMS + WhatsApp) ─────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+2348000000000
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Resend (transactional email) ────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=MyHealth Vault+ <noreply@healthhubafrica.com>

# ─── Firebase FCM (Push notifications) ──────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── Video (TeleCare) ────────────────────────────────────────────
ZOOM_API_KEY=
ZOOM_API_SECRET=


