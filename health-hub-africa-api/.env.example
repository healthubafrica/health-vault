# ─── App ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/hha_db?schema=public

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_EXPIRY=900
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_REFRESH_EXPIRY=604800

# ─── AWS S3 / Cloudflare R2 ──────────────────────────────────────
# Keys are optional — leave blank in AWS to use the ECS task role
# (SDK default credential provider chain). Only set for local dev or R2.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=hha-documents
SIGNED_URL_EXPIRY_SECONDS=3600
# For Cloudflare R2 set endpoint:
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# ─── Paystack ────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_
PAYSTACK_PUBLIC_KEY=pk_live_

# ─── MyHealth Vault+ Clinical Platform ──────────────────────────
# Uses Resource-Owner Password Grant (client_credentials not supported unless
# a SMART-on-FHIR Backend Services client is explicitly registered).
# OPENEMR_USERNAME / OPENEMR_PASSWORD: dedicated service account in the clinical platform.
OPENEMR_BASE_URL=https://clinical.yourdomain.com
OPENEMR_CLIENT_ID=
OPENEMR_CLIENT_SECRET=
OPENEMR_USERNAME=hha_service
OPENEMR_PASSWORD=change_me_in_production
FHIR_BASE_URL=https://clinical.yourdomain.com/apis/default/fhir
OAUTH_TOKEN_URL=https://clinical.yourdomain.com/oauth2/default/token

# ─── Africa's Talking (SMS) ──────────────────────────────────────
AT_USERNAME=sandbox
AT_API_KEY=your_api_key_here
AT_SENDER_ID=

# ─── Resend (transactional email) ────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=MyHealth Vault+ <noreply@healthhubafrica.com>
# Signing secret from Resend dashboard → Webhooks (Svix "whsec_..." value).
# Required for POST /notifications/webhooks/resend to verify delivered/bounced events.
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Sentry ──────────────────────────────────────────────────────
SENTRY_DSN=https://xxxx@oXXXXX.ingest.sentry.io/XXXXXXX

# ─── Firebase FCM (Push notifications) ──────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── LiveKit (TeleCare Video Consultation) ───────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
