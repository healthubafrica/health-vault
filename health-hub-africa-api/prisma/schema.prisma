// MyHealth Vault+™ — Prisma Schema
// Health-Hub Africa® | PostgreSQL 16+
// Generated from schema.md v2.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  patient
  provider
  coordinator
  admin
  super_admin
}

enum AppointmentStatus {
  requested
  confirmed
  upcoming
  in_progress
  completed
  cancelled
  no_show
}

enum ServiceType {
  MinuteCare
  TeleCare
  CareTest
  HealthConsult
  ExpertReview
  NeuroFlex
  DispatchCare
  TravelSafe
}

enum RecordType {
  visit
  prescription
  lab
  imaging
  document
  referral
  expert_review
}

enum DocumentCategory {
  personal_identification
  medical_history
  providers
  specialists
  emergency
  hospital
  laboratory
  imaging
  medications
  vaccinations
  chronic_disease
  womens_health
  childrens_health
  mental_health
  dental
  vision
  travel
  legal
  wearables
  miscellaneous
}

enum DocumentSource {
  patient_upload
  provider_upload
  imported
}

enum LabStatus {
  pending
  normal
  review
  critical
}

enum SessionStatus {
  scheduled
  waiting
  active
  completed
  missed
  cancelled
}

enum EmergencyType {
  Breathing_Difficulty
  Chest_Pain
  Accident_Injury
  Stroke_Symptoms
  Severe_Weakness
  Other
}

enum DispatchStatus {
  requested
  triaged
  unit_assigned
  en_route
  on_scene
  patient_stabilised
  transported
  closed
}

enum PaymentStatus {
  pending
  processing
  paid
  failed
  refunded
  disputed
}

enum PaymentGateway {
  Paystack
  Flutterwave
  manual
}

enum PlanTier {
  Free
  BasicCare
  SilverCare
  GoldCare
  ConciergeCare
}

enum SubscriptionStatus {
  active
  past_due
  cancelled
  expired
  trial
}

enum AlertSeverity {
  info
  warning
  critical
}

enum PhaseStatus {
  planned
  beta
  active
  deprecated
}

enum Gender {
  Male
  Female
  Other
  Prefer_not_to_say @map("Prefer not to say")
}

enum BloodGroup {
  A_PLUS  @map("A+")
  A_MINUS @map("A-")
  B_PLUS  @map("B+")
  B_MINUS @map("B-")
  AB_PLUS @map("AB+")
  AB_MINUS @map("AB-")
  O_PLUS  @map("O+")
  O_MINUS @map("O-")
}

enum ExpertReviewStatus {
  submitted
  under_review
  specialist_assigned
  in_consultation
  report_ready
  closed
  cancelled
}

enum ExpertReviewUrgency {
  routine
  urgent
  emergency
}

enum ExpertReviewType {
  second_opinion
  multi_specialist
  surgical_review
  imaging_review
  pathology_review
}

enum ContentStatus {
  draft
  published
}

// ─── Auth & Users ────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique
  phone         String?   @unique
  passwordHash  String    @map("password_hash")
  role          UserRole  @default(patient)
  isVerified        Boolean   @default(false) @map("is_verified")
  isActive          Boolean   @default(true) @map("is_active")
  twoFactorEnabled  Boolean   @default(false) @map("two_factor_enabled")
  profilePhotoUrl   String?   @map("profile_photo_url")
  lastLoginAt       DateTime? @map("last_login_at")
  failedLoginAttempts Int     @default(0) @map("failed_login_attempts")
  lockedUntil       DateTime? @map("locked_until")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  sessions              UserSession[]
  verificationTokens    VerificationToken[]
  patient               Patient?
  provider              Provider?
  notificationPrefs     NotificationPreference?
  auditLogsAsActor      AuditLog[]            @relation("AuditLogActor")
  supportTicketsSubmitted SupportTicket[]     @relation("TicketSubmitter")
  supportTicketsAssigned  SupportTicket[]     @relation("TicketAssignee")
  supportMessages       SupportMessage[]
  dispatchRequests      DispatchRequest[]     @relation("DispatchRequester")
  dispatchEvents        DispatchEvent[]
  erCasesCoordinator    ExpertReviewCase[]    @relation("ERCoordinator")
  erStatusEvents        ExpertReviewStatusEvent[]
  blogPosts             BlogPost[]
  verifiedProviders     Provider[]            @relation("ProviderVerifier")

  @@map("users")
}

model UserSession {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  refreshToken String    @unique @map("refresh_token")
  ipAddress    String?   @map("ip_address")
  userAgent    String?   @map("user_agent")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityEvents    PatientActivityEvent[]

  @@index([userId])
  @@index([refreshToken])
  @@map("user_sessions")
}

model VerificationToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique
  type      String
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_tokens")
}

// ─── Patients ────────────────────────────────────────────────────────────────

model Patient {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String     @unique @map("user_id") @db.Uuid
  hhaPatientId String    @unique @map("hha_id")
  regionCode  String     @map("region_code") @db.Char(3)
  firstName   String     @map("first_name")
  lastName    String     @map("last_name")
  middleName  String?    @map("middle_name")
  dateOfBirth DateTime   @map("date_of_birth") @db.Date
  gender      Gender
  nationality String?
  stateOfOrigin String?    @map("state_of_origin")
  lgaOfOrigin String?       @map("lga_of_origin")
  profilePhotoUrl String? @map("profile_photo_url")
  address     String?
  city        String?
  state       String?
  country     String     @default("Nigeria")
  bloodGroup  BloodGroup? @map("blood_group")
  nextOfKinName        String? @map("next_of_kin_name")
  nextOfKinRelationship String? @map("next_of_kin_relationship")
  nextOfKinPhone       String? @map("next_of_kin_phone")
  genotype    String?
  nin         String?
  gdprConsent       Boolean    @default(false) @map("gdpr_consent")
  marketingConsent  Boolean    @default(false) @map("marketing_consent")
  preferredTimezone String     @default("Africa/Lagos") @map("preferred_timezone")
  preferredLanguage String     @default("en") @map("preferred_language")
  dateFormat        String     @default("dd/mm/yyyy") @map("date_format")
  openemrPatientUuid String? @unique @map("openemr_patient_uuid")
  openemrSyncStatus  String  @default("pending") @map("openemr_sync_status")
  status      String     @default("Stable")
  profilePhotoSizeBytes      Int?    @map("profile_photo_size_bytes")
  storageQuotaOverrideBytes  BigInt? @map("storage_quota_override_bytes")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  medicalInfo           PatientMedicalInfo?
  emergencyContacts     EmergencyContact[]
  vitalsReadings        VitalsReading[]
  appointments          Appointment[]
  clinicalRecords       ClinicalRecord[]
  labOrders             LabOrder[]
  labResults            LabResult[]
  telecareSessions      TelecareSession[]
  dispatchRequests      DispatchRequest[]
  subscriptions         PatientSubscription[]
  payments              Payment[]
  alerts                PatientAlert[]
  consents              PatientConsent[]
  supportTickets        SupportTicket[]
  activityEvents        PatientActivityEvent[]
  providerAssignments   PatientProviderAssignment[]
  strideLogs            StrideTriage[]
  expertReviewCases     ExpertReviewCase[]
  auditLogs             AuditLog[]                @relation("AuditLogPatient")
  prescriptions         Prescription[]
  invoices              Invoice[]
  syncQueueItems        OpenemrSyncQueue[]
  integrationErrors     IntegrationError[]
  recordShares          RecordShare[]
  travelsafeTrips       TravelSafeTrip[]

  @@index([userId])
  @@index([hhaPatientId])
  @@index([regionCode])
  @@index([openemrPatientUuid])
  @@map("patients")
}

model PatientMedicalInfo {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId        String   @unique @map("patient_id") @db.Uuid
  allergies        String[]
  chronicConditions String[] @map("chronic_conditions")
  activeMedications String[] @map("active_medications")
  activeCarePlan   String?  @map("active_care_plan")
  notes            String?
  updatedAt        DateTime @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("patient_medical_info")
}

model EmergencyContact {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId    String   @map("patient_id") @db.Uuid
  fullName     String   @map("full_name")
  relationship String
  phone        String
  email        String?
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("emergency_contacts")
}

// ─── Providers ───────────────────────────────────────────────────────────────

model Provider {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  firstName       String   @map("first_name")
  lastName        String   @map("last_name")
  title           String   @default("Dr.")
  specialty       String
  licenseNumber   String?  @unique @map("license_number")
  profilePhotoUrl String?  @map("profile_photo_url")
  bio             String?
  rating          Decimal? @db.Decimal(3, 2)
  totalPatients   Int      @default(0) @map("total_patients")
  yearsExperience Int      @default(0) @map("years_experience")
  isAvailable     Boolean  @default(true) @map("is_available")
  verifiedAt      DateTime? @map("verified_at")
  verifiedBy      String?   @map("verified_by") @db.Uuid
  openemrProviderUuid String? @unique @map("openemr_provider_uuid")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifier              User?                     @relation("ProviderVerifier", fields: [verifiedBy], references: [id])
  availability          ProviderAvailability[]
  serviceGroups         ProviderServiceGroup[]
  patientAssignments    PatientProviderAssignment[]
  appointments          Appointment[]
  clinicalRecords       ClinicalRecord[]
  prescriptions         Prescription[]
  labOrders             LabOrder[]
  vitalsRecorded        VitalsReading[]
  telecareSessions      TelecareSession[]
  erCasesLead           ExpertReviewCase[]         @relation("ERLeadPhysician")
  erCasesSpecialist     ExpertReviewCase[]         @relation("ERSpecialist")
  erSpecialistNotes     ExpertReviewSpecialistNote[]
  erFinalReports        ExpertReviewFinalReport[]
  notificationEmails    ProviderNotificationEmail[]

  @@map("providers")
}

model NotificationRecipient {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  label     String
  email     String
  isActive  Boolean  @default(true) @map("is_active")
  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notification_recipients")
}

model ProviderNotificationEmail {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId String   @map("provider_id") @db.Uuid
  label      String?
  email      String
  isActive   Boolean  @default(true) @map("is_active")
  addedBy    String?  @map("added_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("provider_notification_emails")
}

model ProviderAvailability {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId  String      @map("provider_id") @db.Uuid
  dayOfWeek   Int         @map("day_of_week") @db.SmallInt
  startTime   DateTime    @map("start_time") @db.Time
  endTime     DateTime    @map("end_time") @db.Time
  serviceType ServiceType?  @map("service_type")
  isTelecare  Boolean     @default(false) @map("is_telecare")
  createdAt   DateTime    @default(now()) @map("created_at")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_availability")
}

// ─── HHA Scheduling Tables ───────────────────────────────────────────────────

model ProviderServiceGroup {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId  String      @map("provider_id") @db.Uuid
  serviceType ServiceType @map("service_type")
  priority    Int         @default(3)
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  provider         Provider                  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  shiftAssignments ProviderShiftAssignment[]

  @@unique([providerId, serviceType])
  @@index([serviceType, isActive])
  @@map("hha_provider_service_groups")
}

model ShiftTemplate {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  serviceType ServiceType @map("service_type")
  dayOfWeek   Int         @map("day_of_week") @db.SmallInt
  startTime   DateTime    @map("start_time") @db.Time
  endTime     DateTime    @map("end_time") @db.Time
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  assignments ProviderShiftAssignment[]

  @@index([serviceType, isActive])
  @@map("hha_shift_templates")
}

model ProviderShiftAssignment {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerServiceGroupId String  @map("provider_service_group_id") @db.Uuid
  shiftTemplateId      String    @map("shift_template_id") @db.Uuid
  effectiveFrom        DateTime  @map("effective_from") @db.Date
  effectiveTo          DateTime? @map("effective_to") @db.Date
  createdAt            DateTime  @default(now()) @map("created_at")

  providerServiceGroup ProviderServiceGroup @relation(fields: [providerServiceGroupId], references: [id], onDelete: Cascade)
  shiftTemplate        ShiftTemplate        @relation(fields: [shiftTemplateId], references: [id], onDelete: Cascade)

  @@unique([providerServiceGroupId, shiftTemplateId])
  @@map("hha_provider_shift_assignments")
}

model SchedulingPolicy {
  id                      String   @id @db.Uuid
  cancellationWindowHours Int      @default(24) @map("cancellation_window_hours")
  rescheduleWindowHours   Int      @default(24) @map("reschedule_window_hours")
  selfServiceEnabled      Boolean  @default(true) @map("self_service_enabled")
  updatedBy               String?  @map("updated_by") @db.Uuid
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("hha_scheduling_policy")
}

model PatientProviderAssignment {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId    String    @map("patient_id") @db.Uuid
  providerId   String    @map("provider_id") @db.Uuid
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  unassignedAt DateTime? @map("unassigned_at")
  notes        String?

  patient  Patient  @relation(fields: [patientId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])

  @@unique([patientId, providerId, unassignedAt])
  @@map("patient_provider_assignments")
}

// ─── Appointments ────────────────────────────────────────────────────────────

model Appointment {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hhaRef           String            @unique @map("hha_ref")
  patientId        String            @map("patient_id") @db.Uuid
  providerId       String?           @map("provider_id") @db.Uuid
  facilityId       String?           @map("facility_id") @db.Uuid
  serviceType      ServiceType       @map("service_type")
  status           AppointmentStatus @default(requested)
  scheduledAt      DateTime          @map("scheduled_at")
  durationMinutes  Int               @default(30) @map("duration_minutes") @db.SmallInt
  reason           String?
  isTelecare       Boolean           @default(false) @map("is_telecare")
  meetingUrl       String?           @map("meeting_url")
  location         String?
  patientNotes     String?           @map("patient_notes")
  providerNotes    String?           @map("provider_notes")
  cancelledBy      String?           @map("cancelled_by") @db.Uuid
  cancellationNote String?           @map("cancellation_note")
  cancelledAt          DateTime?         @map("cancelled_at")
  previousScheduledAt  DateTime?         @map("previous_scheduled_at")
  rescheduleCount      Int               @default(0) @map("reschedule_count")
  openemrAppointmentId String?       @map("openemr_appointment_id")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  patient    Patient   @relation(fields: [patientId], references: [id])
  provider   Provider? @relation(fields: [providerId], references: [id])
  facility   HealthcareFacility? @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  reminders  AppointmentReminder[]
  telecareSession TelecareSession?
  clinicalRecords ClinicalRecord[]
  labOrders   LabOrder[]
  erCases     ExpertReviewCase[]
  erFollowUpReports ExpertReviewFinalReport[] @relation("ERFollowUpAppointment")
  integrationErrors IntegrationError[]

  @@index([patientId])
  @@index([providerId])
  @@index([facilityId])
  @@index([scheduledAt])
  @@index([status])
  @@map("appointments")
}

model AppointmentReminder {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointmentId String    @map("appointment_id") @db.Uuid
  remindAt      DateTime  @map("remind_at")
  channel       String
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("appointment_reminders")
}

// ─── Clinical Records ────────────────────────────────────────────────────────

model ClinicalRecord {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hhaRef        String     @unique @map("hha_ref")
  patientId     String     @map("patient_id") @db.Uuid
  providerId    String?    @map("provider_id") @db.Uuid
  appointmentId String?    @map("appointment_id") @db.Uuid
  recordType    RecordType @map("record_type")
  title         String
  description   String?
  fileUrl       String?    @map("file_url")
  fileMimeType  String?    @map("file_mime_type")
  fileSizeBytes Int?       @map("file_size_bytes")
  isDownloadable Boolean   @default(true) @map("is_downloadable")
  recordedAt    DateTime   @map("recorded_at") @db.Date
  openemrResourceId String? @unique @map("openemr_resource_id")
  category           DocumentCategory?
  tags               String[]          @default([])
  originalFileName   String?           @map("original_file_name")
  source             DocumentSource    @default(provider_upload)
  providerVisibility Boolean           @default(true) @map("provider_visibility")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  deletedAt     DateTime?  @map("deleted_at")

  patient     Patient      @relation(fields: [patientId], references: [id])
  provider    Provider?    @relation(fields: [providerId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  prescription Prescription?
  sessionNotes TelecareSessionNote[]
  erDocuments  ExpertReviewDocument[]
  erFinalReport ExpertReviewFinalReport?

  @@index([patientId])
  @@index([recordType])
  @@index([recordedAt(sort: Desc)])
  @@index([patientId, category])
  @@map("clinical_records")
}

model Prescription {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recordId        String    @unique @map("record_id") @db.Uuid
  patientId       String    @map("patient_id") @db.Uuid
  providerId      String    @map("provider_id") @db.Uuid
  drugName        String    @map("drug_name")
  dosage          String
  frequency       String
  route           String    @default("oral")
  durationDays    Int?      @map("duration_days")
  refillsRemaining Int      @default(0) @map("refills_remaining")
  dispensedAt     DateTime? @map("dispensed_at")
  expiresAt       DateTime? @map("expires_at") @db.Date
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  record   ClinicalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  patient  Patient        @relation(fields: [patientId], references: [id])
  provider Provider       @relation(fields: [providerId], references: [id])

  @@map("prescriptions")
}

// ─── Lab Tests & Results ─────────────────────────────────────────────────────

model LabOrder {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hhaRef           String    @unique @map("hha_ref")
  patientId        String    @map("patient_id") @db.Uuid
  orderedBy        String    @map("ordered_by") @db.Uuid
  appointmentId    String?   @map("appointment_id") @db.Uuid
  clinicalRecordId String?   @map("clinical_record_id") @db.Uuid
  orderedAt        DateTime  @default(now()) @map("ordered_at")
  collectedAt      DateTime? @map("collected_at")
  reportedAt       DateTime? @map("reported_at")
  overallStatus    LabStatus @default(pending) @map("overall_status")
  labFacility      String?   @map("lab_facility")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  patient     Patient      @relation(fields: [patientId], references: [id])
  provider    Provider     @relation(fields: [orderedBy], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  results     LabResult[]

  @@index([patientId])
  @@map("lab_orders")
}

model LabResult {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId           String    @map("order_id") @db.Uuid
  patientId         String    @map("patient_id") @db.Uuid
  testName          String    @map("test_name")
  testCode          String?   @map("test_code")
  status            LabStatus @default(pending)
  valueDisplay      String?   @map("value_display")
  unit              String?
  referenceRange    String?   @map("reference_range")
  isFlagged         Boolean   @default(false) @map("is_flagged")
  interpretationNote String?  @map("interpretation_note")
  isDownloadable    Boolean   @default(true) @map("is_downloadable")
  fileUrl           String?   @map("file_url")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  order   LabOrder        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  patient Patient         @relation(fields: [patientId], references: [id])
  items   LabResultItem[]

  @@index([orderId])
  @@index([patientId])
  @@map("lab_results")
}

model LabResultItem {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resultId     String  @map("result_id") @db.Uuid
  analyteName  String  @map("analyte_name")
  analyteCode  String? @map("analyte_code")
  value        String
  unit         String?
  referenceLow  String? @map("reference_low")
  referenceHigh String? @map("reference_high")
  isFlagged    Boolean @default(false) @map("is_flagged")
  flagType     String? @map("flag_type")
