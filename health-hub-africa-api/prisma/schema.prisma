  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId      String?   @map("actor_id") @db.Uuid
  patientId    String?   @map("patient_id") @db.Uuid
  action       String
  resourceType String    @map("resource_type")
  resourceId   String?   @map("resource_id") @db.Uuid
  ipAddress    String?   @map("ip_address")
  userAgent    String?   @map("user_agent")
  metadata     Json?
  severity     String    @default("info")
  occurredAt   DateTime  @default(now()) @map("occurred_at")

  actor   User?    @relation("AuditLogActor", fields: [actorId], references: [id])
  patient Patient? @relation("AuditLogPatient", fields: [patientId], references: [id])

  @@index([actorId, occurredAt(sort: Desc)])
  @@index([patientId, occurredAt(sort: Desc)])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

// ─── Support & Tickets ────────────────────────────────────────────────────────

model SupportTicket {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hhaRef        String   @unique @map("hha_ref")
  submittedBy   String   @map("submitted_by") @db.Uuid
  patientId     String?  @map("patient_id") @db.Uuid
  category      String
  subject       String
  status        String   @default("open")
  priority      String   @default("normal")
  assignedTo    String?  @map("assigned_to") @db.Uuid
  referenceType String?  @map("reference_type")
  referenceId   String?  @map("reference_id") @db.Uuid
  resolvedAt    DateTime? @map("resolved_at")
  closedAt      DateTime? @map("closed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  submitter User     @relation("TicketSubmitter", fields: [submittedBy], references: [id])
  assignee  User?    @relation("TicketAssignee", fields: [assignedTo], references: [id])
  patient   Patient? @relation(fields: [patientId], references: [id])
  messages  SupportMessage[]

  @@index([patientId])
  @@index([status])
  @@map("support_tickets")
}

model SupportMessage {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId      String   @map("ticket_id") @db.Uuid
  senderId      String   @map("sender_id") @db.Uuid
  body          String
  attachmentUrl String?  @map("attachment_url")
  isInternal    Boolean  @default(false) @map("is_internal")
  createdAt     DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [senderId], references: [id])

  @@index([ticketId, createdAt(sort: Asc)])
  @@map("support_messages")
}

// ─── OpenEMR Integration ──────────────────────────────────────────────────────

model IntegrationError {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  service         String
  endpoint        String
  method          String    @default("GET")
  requestId       String?   @map("request_id")
  requestPayload  Json?     @map("request_payload")
  errorCode       String?   @map("error_code")
  errorMessage    String?   @map("error_message")
  patientId       String?   @map("patient_id") @db.Uuid
  appointmentId   String?   @map("appointment_id") @db.Uuid
  retryCount      Int       @default(0) @map("retry_count") @db.SmallInt
  resolvedAt      DateTime? @map("resolved_at")
  resolutionNotes String?   @map("resolution_notes")
  occurredAt      DateTime  @default(now()) @map("occurred_at")

  patient     Patient?     @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([service, occurredAt(sort: Desc)])
  @@index([patientId])
  @@index([appointmentId])
  @@map("integration_errors")
}

model OpenemrSyncQueue {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId       String    @map("patient_id") @db.Uuid
  operation       String
  jobType         String?   @map("job_type")
  payload         Json
  status          String    @default("pending")
  attempts        Int       @default(0) @db.SmallInt
  maxAttempts     Int       @default(3) @map("max_attempts") @db.SmallInt
  lastAttemptedAt DateTime? @map("last_attempted_at")
  completedAt     DateTime? @map("completed_at")
  errorMessage    String?   @map("error_message")
  scheduledFor    DateTime  @default(now()) @map("scheduled_for")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([status, scheduledFor(sort: Asc)])
  @@index([patientId])
  @@map("openemr_sync_queue")
}

// ─── Record Shares ────────────────────────────────────────────────────────────

enum ShareAccessMode {
  public
  email_list
  password
}

enum ShareAccessAction {
  viewed
  otp_sent
  otp_failed
  otp_verified
  forward_detected
  revoked
  link_sent
  link_opened
  link_delivered
  share_expired
}

model RecordShare {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId        String          @map("patient_id") @db.Uuid
  tokenHash        String          @unique @map("token_hash")
  label            String?
  accessMode       ShareAccessMode @default(public) @map("access_mode")
  allowedEmails    String[]        @map("allowed_emails")
  passwordHash     String?         @map("password_hash")
  recordTypes      String[]        @map("record_types")
  expiresAt        DateTime?       @map("expires_at")
  isRevoked        Boolean         @default(false) @map("is_revoked")
  revokedAt        DateTime?       @map("revoked_at")
  detectForwarding Boolean         @default(false) @map("detect_forwarding")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  patient     Patient                @relation(fields: [patientId], references: [id])
  accesses    RecordShareAccess[]
  deliveries  NotificationDelivery[]

  @@index([patientId])
  @@map("record_shares")
}

model RecordShareAccess {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shareId            String            @map("share_id") @db.Uuid
  action             ShareAccessAction
  visitorEmail       String?           @map("visitor_email")
  sessionFingerprint String?           @map("session_fingerprint")
  ipAddress          String?           @map("ip_address")
  userAgent          String?           @map("user_agent")
  metadata           Json?
  occurredAt         DateTime          @default(now()) @map("occurred_at")

  share RecordShare @relation(fields: [shareId], references: [id], onDelete: Cascade)

  @@index([shareId, occurredAt(sort: Desc)])
  @@map("record_share_accesses")
}

// ─── Analytics ────────────────────────────────────────────────────────────────

model PatientActivityEvent {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId   String      @map("patient_id") @db.Uuid
  sessionId   String?     @map("session_id") @db.Uuid
  eventName   String      @map("event_name")
  serviceType ServiceType? @map("service_type")
  properties  Json?
  ipAddress   String?     @map("ip_address")
  userAgent   String?     @map("user_agent")
  occurredAt  DateTime    @default(now()) @map("occurred_at")

  patient Patient      @relation(fields: [patientId], references: [id])
  session UserSession? @relation(fields: [sessionId], references: [id])

  @@index([patientId, occurredAt(sort: Desc)])
  @@index([eventName, occurredAt(sort: Desc)])
  @@map("patient_activity_events")
}

model ServiceUsageDaily {
  id                   String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportDate           DateTime    @map("report_date") @db.Date
  serviceType          ServiceType @map("service_type")
  totalSessions        Int         @default(0) @map("total_sessions")
  uniquePatients       Int         @default(0) @map("unique_patients")
  completedCount       Int         @default(0) @map("completed_count")
  cancelledCount       Int         @default(0) @map("cancelled_count")
  avgDurationSeconds   Int?        @map("avg_duration_seconds")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  @@unique([reportDate, serviceType])
  @@index([reportDate(sort: Desc)])
  @@map("service_usage_daily")
}

model RevenueSummary {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportDate          DateTime        @map("report_date") @db.Date
  serviceType         ServiceType?    @map("service_type")
  gateway             PaymentGateway?
  totalTransactions   Int             @default(0) @map("total_transactions")
  grossRevenueKobo    BigInt          @default(0) @map("gross_revenue_kobo")
  refundsKobo         BigInt          @default(0) @map("refunds_kobo")
  netRevenueKobo      BigInt          @default(0) @map("net_revenue_kobo")
  failedCount         Int             @default(0) @map("failed_count")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  @@unique([reportDate, serviceType, gateway])
  @@index([reportDate(sort: Desc)])
  @@map("revenue_summaries")
}

model ExpertReviewFunnelMetric {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportDate           DateTime @unique @map("report_date") @db.Date
  casesSubmitted       Int      @default(0) @map("cases_submitted")
  casesAccepted        Int      @default(0) @map("cases_accepted")
  specialistAssigned   Int      @default(0) @map("specialist_assigned")
  reportsIssued        Int      @default(0) @map("reports_issued")
  avgTurnaroundHours   Decimal? @map("avg_turnaround_hours") @db.Decimal(8, 2)
  p90TurnaroundHours   Decimal? @map("p90_turnaround_hours") @db.Decimal(8, 2)
  cancellationRate     Decimal? @map("cancellation_rate") @db.Decimal(5, 4)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("expert_review_funnel_metrics")
}

model OperationalKpi {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  snapshotAt            DateTime @default(now()) @map("snapshot_at")
  activeSubscriptions   Int      @default(0) @map("active_subscriptions")
  mrrKobo               BigInt   @default(0) @map("mrr_kobo")
  activeDispatchUnits   Int      @default(0) @map("active_dispatch_units")
  openDispatchRequests  Int      @default(0) @map("open_dispatch_requests")
  telecareSessionsToday Int      @default(0) @map("telecare_sessions_today")
  expertCasesOpen       Int      @default(0) @map("expert_cases_open")
  avgStrideLatencyMs    Int?     @map("avg_stride_latency_ms")
  openemrSyncPending    Int      @default(0) @map("openemr_sync_pending")
  createdAt             DateTime @default(now()) @map("created_at")

  @@map("operational_kpis")
}

// ─── CMS (Marketing Site Content) ────────────────────────────────────────────

model BlogPost {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String
  slug            String        @unique
  excerpt         String
  bodyHtml        String        @map("body_html")
  coverImageUrl   String?       @map("cover_image_url")
  category        String
  tags            String[]      @default([])
  status          ContentStatus @default(draft)
  publishedAt     DateTime?     @map("published_at")
  authorName      String        @map("author_name")
  authorTitle     String?       @map("author_title")
  seoTitle        String?       @map("seo_title")
  seoDescription  String?       @map("seo_description")
  readMinutes     Int?          @map("read_minutes") @db.SmallInt
  createdById     String?       @map("created_by_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  createdBy User? @relation(fields: [createdById], references: [id])

  @@index([status, publishedAt(sort: Desc)])
  @@index([slug])
  @@map("blog_posts")
}

model Testimonial {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authorName     String        @map("author_name")
  authorTitle    String?       @map("author_title")
  authorCompany  String?       @map("author_company")
  authorPhotoUrl String?       @map("author_photo_url")
  quote          String
  rating         Int           @default(5) @db.SmallInt
  isFeatured     Boolean       @default(false) @map("is_featured")
  status         ContentStatus @default(draft)
  serviceType    ServiceType?  @map("service_type")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@index([status, isFeatured])
  @@map("testimonials")
}

// ─── TravelSafe ───────────────────────────────────────────────────────────────

enum TravelSafeStatus {
  preparing
  active
  completed
  cancelled
}

model TravelSafeTrip {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId          String           @map("patient_id") @db.Uuid
  partnerCode        String?          @map("partner_code")
  partnerName        String?          @map("partner_name")
  destinationCountry String           @map("destination_country")
  departureDate      DateTime         @map("departure_date") @db.Date
  returnDate         DateTime?        @map("return_date") @db.Date
  purpose            String?
  status             TravelSafeStatus @default(preparing)
  notes              String?
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("travelsafe_trips")
}
